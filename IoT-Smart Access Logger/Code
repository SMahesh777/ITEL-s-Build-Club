#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <ESP32Servo.h>
#include <EEPROM.h>
#include <WiFi.h>
#include <SPI.h>
#include <MFRC522.h>
// ------------------- BLYNK SETTINGS -------------------
#define BLYNK_TEMPLATE_ID "TEMPLATE_ID"
#define BLYNK_TEMPLATE_NAME "TEMPLATE_NAME"
#define BLYNK_AUTH_TOKEN "BLYNK_AUTH_TOKEN"
#include <BlynkSimpleEsp32.h>
// ------------------- PIN CONFIG -------------------
#define SERVO_PIN 7
// I2C pins for ESP32-C6 (LCD)
#define I2C_SDA 4
#define I2C_SCL 5
// RC522 RFID (SPI)
#define SS_PIN 21
#define RST_PIN 22
#define MOSI_PIN 23
#define MISO_PIN 19
#define SCK_PIN 18
// ------------------- OBJECTS -------------------
LiquidCrystal_I2C lcd(0x27, 16, 2);
Servo doorServo;
MFRC522 mfrc522(SS_PIN, RST_PIN); // Create MFRC522 instance
BlynkTimer timer;
// ------------------- ACCESS CONTROL -------------------
String allowedCards[] = { "53FCC129", "D1472A02" }; // Add allowed UIDs here
int totalEntries = 0;
int accessGranted = 0;
int accessDenied = 0;
// Wi-Fi credentials
const char* ssid = "ENTER_YOUR_SSID";
const char* password = "ENTER_YOUR_PASSWORD";
// ------------------- SETUP -------------------
void setup() {
Serial.begin(115200);
Wire.begin(I2C_SDA, I2C_SCL);
lcd.begin();
lcd.backlight();
lcd.print("Connecting WiFi...");
WiFi.begin(ssid, password);
while (WiFi.status() != WL_CONNECTED) {
delay(500);
lcd.print(".");
}
lcd.clear();
lcd.print("WiFi Connected");
// Initialize Blynk (non-blocking)
Blynk.config(BLYNK_AUTH_TOKEN);
Blynk.connect(); // Connect to Blynk server
// Initialize servo
doorServo.attach(SERVO_PIN);
doorServo.write(0);
// Initialize RFID AFTER WiFi + Blynk
SPI.begin(SCK_PIN, MISO_PIN, MOSI_PIN, SS_PIN);
mfrc522.PCD_Init();
// Timer to send data to Blynk every 5 seconds
timer.setInterval(5000L, sendDataToBlynk);
lcd.clear();
lcd.print("System Ready");
}
// ------------------- LOOP -------------------
void loop() {
Blynk.run();
timer.run();
if (!mfrc522.PICC_IsNewCardPresent()) return;
if (!mfrc522.PICC_ReadCardSerial()) return;
// Read UID
String cardID = "";
for (byte i = 0; i < mfrc522.uid.size; i++) {
if (mfrc522.uid.uidByte[i] < 0x10) cardID += "0";
cardID += String(mfrc522.uid.uidByte[i], HEX);
}
cardID.toUpperCase();
Serial.println("Scanned UID: " + cardID);
totalEntries++;
if (isCardAllowed(cardID)) {
grantAccess();
accessGranted++;
} else {
denyAccess();
accessDenied++;
}
}
// ------------------- FUNCTIONS -------------------
bool isCardAllowed(String cardID) {
for (String uid : allowedCards) {
if (uid == cardID) return true;
}
return false;
}
void grantAccess() {
lcd.clear();
lcd.print("Access Granted");
doorServo.write(90);
delay(1000); // small delay to allow servo to move
doorServo.write(0);
lcd.clear();
lcd.print("System Ready");
}
void denyAccess() {
lcd.clear();
lcd.print("Access Denied");
delay(1000); // small delay for user to see message
lcd.clear();
lcd.print("System Ready");
}
// ------------------- BLYNK DATA -------------------
void sendDataToBlynk() {
Blynk.virtualWrite(V0, totalEntries);
Blynk.virtualWrite(V1, accessGranted);
Blynk.virtualWrite(V2, accessDenied);
Serial.printf("Total: %d | Granted: %d | Denied: %d\n", totalEntries, accessGranted,
accessDenied);
}
