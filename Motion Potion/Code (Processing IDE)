void serialEvent(Serial p) {
String data = trim(p.readStringUntil('\n'));
if (data != null && data.length() > 0) {
String[] vals = split(data, ',');
if (vals.length >= 3) {
try {
pitch = float(vals[0]);
roll = float(vals[1]);
yaw = float(vals[2]);
} catch (Exception e) {
println("Parse error: " + e.getMessage());
}
}
}
