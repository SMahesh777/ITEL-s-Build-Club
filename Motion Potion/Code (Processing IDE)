import processing.serial.*;
Serial port;
float pitch = 0, roll = 0, yaw = 0;
float smoothPitch = 0, smoothRoll = 0, smoothYaw = 0;
float lerpSpeed = 0.15;
// Calibration offsets — captured when user presses C
float offsetPitch = 0;
float offsetRoll = 0;
float offsetYaw = 0;
boolean calibrated = false;
// Button
float btnX = 20, btnY = 590, btnW = 220, btnH = 38;
boolean btnHover = false;
void setup() {
size(900, 650, P3D);
port = new Serial(this, "COM3", 115200); // Change COM3 to your port port.bufferUntil('\n');
}
void draw() {
background(15, 15, 30);
float adjPitch = pitch - offsetPitch;
float adjRoll = roll - offsetRoll;
float adjYaw = yaw - offsetYaw;
smoothPitch = lerp(smoothPitch, adjPitch, lerpSpeed);
smoothRoll = lerp(smoothRoll, adjRoll, lerpSpeed);
smoothYaw = lerp(smoothYaw, adjYaw, lerpSpeed);
hint(DISABLE_DEPTH_TEST);
camera();
noLights();
drawHUD();
drawButton();
hint(ENABLE_DEPTH_TEST);
ambientLight(60, 60, 80);
directionalLight(255, 240, 220, -1, -1, -1);
directionalLight(40, 60, 100, 1, 1, 0.5);
translate(width / 2, height / 2 - 20, 0);
rotateX(radians(smoothPitch));
rotateY(radians(smoothYaw));
rotateZ(radians(-smoothRoll));
scale(2.2);
drawJet();
}
void calibrate() {
offsetPitch = pitch;
offsetRoll = roll;
offsetYaw = yaw;
smoothPitch = 0;
smoothRoll = 0;
smoothYaw = 0;
calibrated = true;
}
void mousePressed() {
if (mouseX > btnX && mouseX < btnX + btnW && mouseY > btnY && mouseY < btnY + btnH) {
calibrate();
}
}
void mouseMoved() {
btnHover = (mouseX > btnX && mouseX < btnX + btnW && mouseY > btnY && mouseY < btnY + btnH);
}
void keyPressed() {
if (key == 'c' || key == 'C') calibrate();
}
void drawButton() {
if (calibrated && !btnHover) {
fill(20, 80, 40);
} else if (btnHover) {
fill(50, 100, 200);
} else {
fill(30, 60, 130);
}
noStroke();
rect(btnX, btnY, btnW, btnH, 7);
stroke(180, 210, 255, 180);
strokeWeight(1.5);
float cx = btnX + 20, cy = btnY + btnH / 2;
line(cx - 7, cy, cx + 7, cy);
line(cx, cy - 7, cx, cy + 7);
ellipse(cx, cy, 10, 10);
noStroke();
fill(200, 220, 255);
textSize(13);
textAlign(LEFT, CENTER);
text(calibrated ? "Re-calibrate Horizon [C]" : "Calibrate Horizon [C]", btnX + 38, btnY + btnH / 2);
}
void drawHUD() {
fill(0, 0, 0, 140);
noStroke();
rect(14, 14, 220, 130, 8);
fill(180, 210, 255);
textSize(12);
textAlign(LEFT);
text("MPU6050 | ESP32C6", 26, 34);
textSize(11);
fill(calibrated ? color(80, 200, 100) : color(255, 160, 60));
text(calibrated ? “Calibrated" : "Place flat and press C", 26, 52);
textSize(14);
fill(100, 220, 140);
text("PITCH " + nf(smoothPitch, 3, 1) + "°", 26, 72);
fill(100, 180, 255);
text("ROLL " + nf(smoothRoll, 3, 1) + "°", 26, 92);
fill(255, 200, 80);
text("YAW " + nf(smoothYaw, 3, 1) + "°", 26, 112);
drawBar(26, 126, smoothPitch, color(100, 220, 140));
drawBar(96, 126, smoothRoll, color(100, 180, 255));
drawBar(166, 126, smoothYaw, color(255, 200, 80));
}
void drawBar(float x, float y, float val, color c) {
float w = 60;
float filled = map(constrain(val, -90, 90), -90, 90, 0, w);
fill(40, 40, 60);
noStroke();
rect(x, y, w, 7, 3);
fill(c);
rect(x, y, filled, 7, 3);
}
